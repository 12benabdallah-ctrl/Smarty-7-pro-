rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: reminders
    // Document ID: auto-generated
    // Fields:
    //   - task: string (required) - Task description
    //   - datetime: string (required, ISO8601) - Reminder time
    //   - repeat: string (optional, enum) - none, daily, weekly, monthly
    //   - original_text: string (optional) - Original command
    //   - userId: string (required) - Owner UID
    //   - createdAt: timestamp (required) - Creation time
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return (isAuthenticated() && request.auth.uid == userId) || userId == 'guest_user_id';
    }

    function isValidReminder(data) {
      return data.keys().hasAll(['task', 'datetime', 'userId', 'createdAt']) &&
             data.task is string && data.task.size() > 0 && data.task.size() < 500 &&
             data.datetime is string &&
             (data.userId == request.auth.uid || data.userId == 'guest_user_id') &&
             data.createdAt is timestamp;
    }

    match /reminders/{reminderId} {
      allow read: if (isAuthenticated() && resource.data.userId == request.auth.uid) || resource.data.userId == 'guest_user_id';
      allow create: if (isAuthenticated() || request.resource.data.userId == 'guest_user_id') && isValidReminder(request.resource.data);
      allow update: if isOwner(resource.data.userId) && isValidReminder(request.resource.data);
      allow delete: if isOwner(resource.data.userId);
    }
  }
}
